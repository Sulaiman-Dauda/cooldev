# CoolDev runtime environment example
# Copy only the variables you actually need into your production environment.

# -----------------------------------------------------------------------------
# Core server runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
HOST=0.0.0.0
PORT=80
COOLDEV_SERVER_PORT=3001
COOLDEV_DATA_DIR=/var/lib/cooldev
COOLDEV_DOCKER_SOCKET_PATH=/var/run/docker.sock

# -----------------------------------------------------------------------------
# Bootstrap + workspace runtime wiring
# -----------------------------------------------------------------------------
# Public bootstrap URL shown to the first owner before a custom domain is live.
COOLDEV_BOOTSTRAP_URL=http://203.0.113.10:3001

# Internal runtime URL used by the CoolDev server.
COOLDEV_PLATFORM_BASE_URL=http://coolify:8080

# Server-side runtime token created during install.
COOLDEV_PLATFORM_API_TOKEN=replace-with-server-side-platform-token

# -----------------------------------------------------------------------------
# Password reset and auth
# -----------------------------------------------------------------------------
COOLDEV_PASSWORD_RESET_TTL_MINUTES=30

# -----------------------------------------------------------------------------
# SMTP (optional)
# If SMTP is not configured, password reset links are written to the server log.
# -----------------------------------------------------------------------------
COOLDEV_SMTP_HOST=smtp.example.com
COOLDEV_SMTP_PORT=587
COOLDEV_SMTP_SECURE=false
COOLDEV_SMTP_USER=mailer@example.com
COOLDEV_SMTP_PASS=replace-with-smtp-password
COOLDEV_SMTP_FROM=CoolDev <noreply@example.com>

# -----------------------------------------------------------------------------
# Installer / operational defaults (optional)
# -----------------------------------------------------------------------------
# The release bundle stamps this to the published versioned image for that release.
# If you use this source template directly, set it to your published GHCR image.
COOLDEV_IMAGE=
COOLDEV_PORT=3001
COOLDEV_PLATFORM_HEALTH_URL=http://127.0.0.1:8000
